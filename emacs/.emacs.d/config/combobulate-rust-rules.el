;; Inject Rust rules into combobulate alists
(defun combobulate-rust-rules--inject ()
  "Add Rust production rules to combobulate alists."
  (unless (assq 'rust combobulate-rules-alist)
    (push `(rust ,combobulate-rules-rust) combobulate-rules-alist))
  (unless (assq 'rust combobulate-rules-inverse-alist)
    (push `(rust ,combobulate-rules-rust-inverse) combobulate-rules-inverse-alist))
  (unless (assq 'rust combobulate-rules-types-alist)
    (push `(rust ,combobulate-rules-rust-types) combobulate-rules-types-alist))
  (unless (assq 'rust combobulate-rules-supertypes-alist)
    (push `(rust ,combobulate-rules-rust-supertypes) combobulate-rules-supertypes-alist)))

(combobulate-rust-rules--inject)

(provide 'combobulate-rust-rules)
